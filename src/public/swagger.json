{
  "openapi": "3.0.3",
  "info": {
    "title": "Mentorship Quest Platform API",
    "description": "REST API для платформы квеста кураторов учебных групп.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost",
      "description": "Local server"
    }
